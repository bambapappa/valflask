---
interface Props {
  hash: string;
  lastRun: string;
  parties: Array<{ code: string; name: string }>;
}
const { hash, lastRun, parties } = Astro.props;
---
<header class="siteheader">
  <div class="siteheader__brand">
    <a href="/" class="siteheader__title">
      DRYGAST<span class="markering">.NU</span>
    </a>
    <div class="etikett siteheader__meta">
      Vågstation för valfläsk · Uppdaterad {new Date(lastRun).toLocaleDateString("sv-SE")} · Akt {hash.slice(0, 8)}
    </div>
  </div>
  <nav aria-label="Huvudnavigation" class="siteheader__nav">
    <ul class="siteheader__menu">
      <li><a href="/" class="etikett siteheader__link">Start</a></li>
      <li><a href="/fragor" class="etikett siteheader__link">Frågorna</a></li>
      <li><a href="/veckans-flask" class="etikett siteheader__link">Veckans fläsk</a></li>
      <li><a href="/svangningar" class="etikett siteheader__link">Svängregistret</a></li>
      <li><a href="/jamfor" class="etikett siteheader__link">Jämför</a></li>
      <li><a href="/regeringar" class="etikett siteheader__link">Regeringar</a></li>
      <li><a href="/topplistor" class="etikett siteheader__link">Topplistor</a></li>
      <li><a href="/metod" class="etikett siteheader__link">Metod</a></li>
      <li><a href="/rattelser" class="etikett siteheader__link">Rättelser</a></li>
      <li><a href="/om" class="etikett siteheader__link">Om</a></li>
      <li><a href="/api" class="etikett siteheader__link">API</a></li>
    </ul>
  </nav>
</header>

<style>
  .siteheader__title {
    font-family: var(--font-display);
    text-transform: uppercase;
    letter-spacing: var(--sparrning-display);
    font-size: var(--steg-3);
    text-decoration: none;
  }
  .siteheader__nav {
    border-top: var(--linje-sektion);
    padding-top: 0.5rem;
    margin-top: 0.5rem;
  }
  .siteheader__menu {
    display: flex;
    flex-wrap: wrap;
    gap: 0 1.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .siteheader__link {
    text-decoration: none;
  }
</style>
