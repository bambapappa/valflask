---
import { isEnabled } from "../config";
import Annonslank from "./Annonslank.astro";

interface Bok {
  titel: string;
  forfattare: string;
  url: string;
  beskrivning?: string;
}

const bocker: Bok[] = [];

const enabled = isEnabled("E1_AFFILIATE");
---
{enabled && bocker.length > 0 && (
  <aside class="las-vidare">
    <div class="las-vidare__header">
      <h3 class="las-vidare__rubrik">Läs vidare</h3>
      <Annonslank />
    </div>
    <ul class="las-vidare__lista">
      {bocker.map((bok) => (
        <li>
          <a href={bok.url} rel="sponsored nofollow">{bok.titel}</a>
          {bok.forfattare && <span class="las-vidare__forfattare"> — {bok.forfattare}</span>}
          {bok.beskrivning && <p class="las-vidare__beskrivning">{bok.beskrivning}</p>}
        </li>
      ))}
    </ul>
  </aside>
)}

<style>
  .las-vidare {
    border-top: 1px solid var(--linje-svag);
    border-bottom: 1px solid var(--linje-svag);
    padding: 1rem 0;
    margin: 2rem 0;
  }
  .las-vidare__header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }
  .las-vidare__rubrik {
    font-family: var(--font-mono);
    font-size: var(--steg--1);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--dis);
    margin: 0 0 0.65rem;
  }
  .las-vidare__lista {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .las-vidare__lista li {
    margin-bottom: 0.5rem;
    font-size: var(--steg--1);
  }
  .las-vidare__forfattare {
    color: var(--dis);
  }
  .las-vidare__beskrivning {
    font-size: var(--steg--1);
    color: var(--dis);
    margin: 0.15rem 0 0;
  }
</style>
