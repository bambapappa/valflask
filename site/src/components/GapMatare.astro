---
interface Props {
  flasket: number;
  reformutrymme: number | "VERIFIERA";
  reformutrymmeSource?: string | null;
}

const { flasket, reformutrymme, reformutrymmeSource } = Astro.props;
const hasRef = reformutrymme !== "VERIFIERA" && typeof reformutrymme === "number";
const ref4 = hasRef ? (reformutrymme as number) * 4 : 0;
const perYearMdkr = hasRef ? Math.round((reformutrymme as number) / 1000) : 0;
const sourceUrl = reformutrymmeSource ? reformutrymmeSource.split(/\s/)[0] : null;
const gap = hasRef ? Math.max(0, flasket - ref4) : 0;
const maxVal = hasRef ? Math.max(flasket, ref4) : flasket;
const barWidth = 600;
const flasketPx = maxVal > 0 ? Math.round((flasket / maxVal) * barWidth) : 0;
const refPx = hasRef && maxVal > 0 ? Math.round((ref4 / maxVal) * barWidth) : 0;
const flasketMdkr = (flasket / 1000).toFixed(0);
const ref4Mdkr = hasRef ? (ref4 / 1000).toFixed(0) : "";
const overcovered = hasRef && flasket < ref4;
---
<div class="gapmatare">
  <div class="etikett gapmatare__label">Löftena mot vad staten har råd att satsa · 2027–2030</div>
  {hasRef ? (
    <svg class="gapmatare__svg" viewBox={`0 0 ${barWidth} 40`} preserveAspectRatio="none" role="img" aria-label={`Löftena ${flasketMdkr} miljarder mot utrymmet för satsningar ${ref4Mdkr} miljarder`}>
      <rect class="gapmatare__bg" x="0" y="0" width={barWidth} height="40" />
      <rect class="gapmatare__ref" x="0" y="0" width={refPx} height="40" />
      <rect class="gapmatare__fill" x="0" y="0" width={flasketPx} height="40" />
      {gap > 0 && (
        <rect class="gapmatare__gap-bar" x={refPx} y="0" width={Math.abs(flasketPx - refPx)} height="40" />
      )}
    </svg>
  ) : (
    <div class="gapmatare__unverified">
      <svg class="gapmatare__svg" viewBox={`0 0 ${barWidth} 40`} preserveAspectRatio="none" role="img" aria-label={`Löftena ${flasketMdkr} miljarder, utrymmet ännu inte fastställt`}>
        <rect class="gapmatare__bg" x="0" y="0" width={barWidth} height="40" />
        <rect class="gapmatare__fill" x="0" y="0" width={flasketPx} height="40" />
      </svg>
      <div class="gapmatare__method-note">
        <span class="stampel">SIFFRA SAKNAS</span> — vi har ännu ingen pålitlig siffra för hur mycket staten har råd att satsa (vi väntar på Konjunkturinstitutets bedömning). Mätaren visar därför bara löftessumman.
      </div>
    </div>
  )}
  <div class="gapmatare__legend">
    <span class="num">Löftena: <span class="belopp">{flasketMdkr} mdkr</span></span>
    <span class="num">{hasRef ? (<>Att satsa (4 år): <span class="belopp">{ref4Mdkr} mdkr</span></>) : 'Att satsa: siffra saknas'}</span>
  </div>
  {hasRef && gap > 0 && (
    <div class="etikett gapmatare__gap">
      <span class="markering">GAP <span class="belopp">≈ {(gap / 1000).toFixed(0)} MDKR</span></span>
    </div>
  )}
  {overcovered && (
    <div class="etikett gapmatare__gap">
      <span class="stampel">RYMS</span> Löftena ryms i det staten har råd att satsa
    </div>
  )}
  {hasRef && (
    <p class="gapmatare__forklaring">
      <span class="markering">Att satsa</span> = regeringens egen reformbudget för 2026 — knappt {perYearMdkr} miljarder per år, utöver försvar och Ukrainastöd — utslaget på mandatperiodens fyra år. Ett konkret, officiellt tal; Konjunkturinstitutets bedömning av utrymmet är ännu snävare.
      {sourceUrl && <> <a href={sourceUrl} rel="nofollow">Källa<span aria-hidden="true"> ↗</span></a> ·</>} <a href="/metod#gap">Så räknar vi</a>
    </p>
  )}
</div>

<style>
  .gapmatare {
    margin: 1.5rem 0;
  }
  .gapmatare__label {
    margin-bottom: 0.5rem;
  }
  .gapmatare__svg {
    display: block;
    width: 100%;
    height: 2.5rem;
  }
  .gapmatare__bg {
    fill: var(--papper);
    stroke: var(--linje-svag);
    stroke-width: 1;
  }
  .gapmatare__fill {
    fill: var(--svarta);
  }
  .gapmatare__ref {
    fill: transparent;
    stroke: var(--gul);
    stroke-width: 2;
  }
  .gapmatare__gap-bar {
    fill: var(--gul);
    opacity: 0.6;
  }
  .gapmatare__unverified {
    position: relative;
  }
  .gapmatare__method-note {
    font-family: var(--font-mono);
    font-size: var(--steg--1);
    color: var(--dis);
    margin-top: 0.35rem;
  }
  .gapmatare__legend {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-mono);
    font-size: var(--steg--1);
    margin-top: 0.25rem;
  }
  .gapmatare__gap {
    color: var(--svarta);
    margin-top: 0.25rem;
  }
  .gapmatare__forklaring {
    font-family: var(--font-mono);
    font-size: var(--steg--1);
    color: var(--dis);
    margin-top: 0.5rem;
    max-width: 60ch;
  }
</style>
