---
import Layout from "../../layouts/Layout.astro";
import MetodLank from "../../components/MetodLank.astro";
import Dela from "../../components/Dela.astro";
import { getChronicles, getPromises } from "../../lib/data";

export function getStaticPaths() {
  const chronicles = getChronicles();
  return chronicles.map((c) => ({ params: { slug: c.slug }, props: { chronicle: c } }));
}

const { chronicle } = Astro.props;
const { slug } = Astro.params;
const [year, week] = slug.split("-");
const canonicalPath = `/veckans-flask/${slug}`;

// id → slug, för att göra [p-2026-XXXX] till länkar.
const slugById = new Map(getPromises().map((p) => [p.id, p.slug]));

function escapeHtml(s: string): string {
  return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
}

/** Enkel rendering: stycken + [p-2026-XXXX] → länk till löftet. Texten escapas
 *  först; bara kända löftes-id görs om till länkar (inga andra HTML-taggar). */
function renderBody(md: string): string {
  return md
    .split(/\n{2,}/)
    .map((para) => {
      const html = escapeHtml(para.trim()).replace(/\[(p-\d{4}-\d{4})\]/g, (m, id) => {
        const s = slugById.get(id);
        return s ? `<a href="/lofte/${id}/${s}">[${id}]</a>` : m;
      });
      return `<p>${html}</p>`;
    })
    .join("\n");
}

const bodyHtml = renderBody(chronicle.body_md);

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": chronicle.headline,
    "description": `Veckans fläsk, vecka ${week} ${year}: ${chronicle.headline}`,
    "url": `https://drygast.nu${canonicalPath}`,
    "datePublished": chronicle.generated_at,
    "author": { "@type": "Organization", "name": "drygast.nu" },
    "publisher": { "@type": "Organization", "name": "drygast.nu" },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Hem", "item": "https://drygast.nu/" },
      { "@type": "ListItem", "position": 2, "name": `Vecka ${week}`, "item": `https://drygast.nu${canonicalPath}` },
    ],
  },
];
---
<Layout title={`Veckans fläsk v${week} ${year} — drygast.nu`} description={`Veckans fläsk, vecka ${week} ${year}: ${chronicle.headline}`} jsonLd={jsonLd} canonicalPath={canonicalPath}>
  <div class="page-content">
    <div class="prosa-content prosa-content--centered">
      <div class="etikett etikett--week">Veckans fläsk · Vecka {week} {year}</div>
      <h1>{chronicle.headline}</h1>

      {chronicle.correction_note && (
        <aside class="rattelse-not">
          <div class="etikett num">RÄTTAD</div>
          <p>{chronicle.correction_note} <a href="/rattelser">Rättelseloggen</a>.</p>
        </aside>
      )}

      <article class="kronika" set:html={bodyHtml} />

      <MetodLank />

      <Dela path={canonicalPath} title={`Veckans fläsk v${week} ${year} — drygast.nu`} text={`${chronicle.headline} — Veckans fläsk på drygast.nu`} />
    </div>
  </div>
</Layout>

<style>
  .prosa-content--centered {
    margin: 0 auto;
  }
  .etikett--week {
    margin-bottom: 0.5rem;
  }
  .rattelse-not {
    border: 1px solid var(--svarta);
    border-left: 4px solid var(--svarta);
    padding: 0.75rem 1rem;
    margin: 1rem 0 1.5rem;
  }
  .rattelse-not p {
    margin: 0.35rem 0 0;
    font-size: 0.9rem;
    color: var(--grafit);
  }
  .kronika :global(p) {
    margin: 0 0 1rem;
  }
</style>
