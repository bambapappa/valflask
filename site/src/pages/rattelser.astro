---
import Layout from "../layouts/Layout.astro";
import { getRattelser } from "../lib/data";

const rattelser = [...getRattelser()].sort((a, b) => (a.date < b.date ? 1 : -1));

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Hem", "item": "https://drygast.nu/" },
      { "@type": "ListItem", "position": 2, "name": "Rättelser", "item": "https://drygast.nu/rattelser" },
    ],
  },
];
---
<Layout title="Rättelser — drygast.nu" description="Rättelselogg för drygast.nu. Fel rättas synligt, aldrig i tysthet." jsonLd={jsonLd} canonicalPath="/rattelser">
  <div class="page-content">
    <div class="prosa-content prosa-content--centered">
      <h1>Rättelser</h1>
      <p>Fel rättas synligt på denna sida, aldrig i tysthet. Tyst rättelse är förbjuden — varje korrigering har ett publikt spår.</p>

      <h2>Så går en rättelse till</h2>
      <p>Hittar vi ett fel — i en siffra, ett citat, en källa eller en uträkning — rättar vi det och skriver ner vad som ändrades och varför. Varje sådan ändring sparas öppet, så att vem som helst kan se exakt vad som rättats.</p>
      <p>Ett exempel: "Löfte p-2026-0142 — beloppet rättat från 12 miljarder till 8 miljarder efter en ny uppgift från TT." Sajten uppdateras sedan automatiskt med de rättade siffrorna, och alla rättelser listas här med datum, i tidsordning.</p>
      <p>Partier, journalister och allmänhet kan anmäla fel via kontaktuppgifterna på <a href="/press">press-sidan</a>. Varje anmälan kontrolleras mot källan innan vi publicerar en rättelse.</p>

      <h2>Registrerade rättelser</h2>
      {rattelser.length === 0 ? (
        <p>Inga rättelser har registrerats ännu.</p>
      ) : (
        rattelser.map((r) => (
          <article class="rattelse">
            <div class="etikett num">{r.date} · {r.affects}</div>
            <p><strong>Vad:</strong> {r.what}</p>
            <p><strong>Varför:</strong> {r.why}</p>
          </article>
        ))
      )}
    </div>
  </div>
</Layout>

<style>
  .prosa-content--centered {
    margin: 0 auto;
  }
  .rattelse {
    border-top: 1px solid var(--svarta);
    padding: 0.75rem 0 0.5rem;
    margin-top: 0.75rem;
  }
  .rattelse p {
    margin: 0.4rem 0;
    font-size: 0.95rem;
  }
</style>
