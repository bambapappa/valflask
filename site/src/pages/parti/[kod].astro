---
import Layout from "../../layouts/Layout.astro";
import Lopsedel from "../../components/Lopsedel.astro";
import GapMatare from "../../components/GapMatare.astro";
import MetodLank from "../../components/MetodLank.astro";
import KallRad from "../../components/KallRad.astro";
import Dela from "../../components/Dela.astro";
import { getPromises, getParties, getConstants } from "../../lib/data";
import { formatMsek, formatMsekShort } from "../../lib/calc";
import { partyTotalMsek, getPromisesForParty, financingGap, totalFlasket, categoryBreakdown, flasketPerRost, promiseTotalMsek } from "../../lib/aggregates";

export function getStaticPaths() {
  const parties = getParties();
  return parties.map((p) => ({ params: { kod: p.code } }));
}

const { kod } = Astro.params;
const promises = getPromises();
const parties = getParties();
const constants = getConstants();
const party = parties.find((p) => p.code === kod)!;
const partyPromises = getPromisesForParty(promises, kod);
const total = partyTotalMsek(promises, kod);
const flasket = totalFlasket(promises);
const gap = financingGap(promises);
const reformutrymme = constants.reformutrymme_msek_per_ar.value;
const perRost = flasketPerRost(total, party.votes_2022);
const categories = categoryBreakdown(partyPromises);
const canonicalPath = `/parti/${kod}`;
const hasLlm = partyPromises.some((p) => p.cost.basis === 'llm_estimat');
const pageTitle = hasLlm
  ? `Vad kostar ${party.name}s vallöften 2026? ≈ ${formatMsekShort(total)} mdkr — drygast.nu`
  : `Vad kostar ${party.name}s vallöften 2026? ${formatMsekShort(total)} mdkr — drygast.nu`;

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Hem", "item": "https://drygast.nu/" },
      { "@type": "ListItem", "position": 2, "name": party.name, "item": `https://drygast.nu${canonicalPath}` },
    ],
  },
];
---
<Layout title={pageTitle} description={`${party.name}s vallöften 2026 kostar ${formatMsekShort(total)} mdkr för mandatperioden. Oberoende, källspårad.`} ogImage={`/og/parti-${kod}.png`} jsonLd={jsonLd} canonicalPath={canonicalPath}>
  <div class="page-content">
    <Lopsedel total={formatMsek(total)} subtitle={party.name.toUpperCase()} count={partyPromises.length} date="2026" />

    <div class="prosa-content prosa-content--centered">
      <p><strong>{party.name}s</strong> vallöften 2026 kostar hittills <strong class="num">{formatMsekShort(total)} mdkr</strong> för de fyra åren 2027–2030, fördelat på {partyPromises.length} löften. Fläsk per röst: <strong class="num">{Math.round(perRost).toLocaleString("sv-SE")} kr</strong> ({party.mandate_2022} mandat, {party.votes_2022.toLocaleString("sv-SE")} röster 2022).</p>
      <p class="manifest-status">{party.manifest_2026}</p>
    </div>

    <MetodLank />

    <GapMatare flasket={flasket} reformutrymme={reformutrymme} />

    <section class="sektion">
      <h2>Kategorifördelning</h2>
      <div class="datavy datavy--scroll">
        <table>
          <thead>
            <tr>
              <th class="radnr">#</th>
              <th>Kategori</th>
              <th class="num">Totalt (mdkr)</th>
              <th class="num">Löften</th>
            </tr>
          </thead>
          <tbody>
            {categories.map((cat, i) => (
              <tr>
                <td class="radnr">{i + 1}</td>
                <td>{cat.category}</td>
                <td class="num">{formatMsek(cat.totalMsek)}</td>
                <td class="num">{cat.count}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="sektion">
      <h2>{party.name}:s löften</h2>
      <div class="datavy datavy--scroll">
        <table>
          <thead>
            <tr>
              <th class="radnr">#</th>
              <th>Löfte</th>
              <th>Kategori</th>
              <th class="num">Kostnad (mdkr)</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            {partyPromises.map((p, i) => (
              <tr>
                <td class="radnr">{i + 1}</td>
                <td><a href={`/lofte/${p.id}/${p.slug}`}>{p.title}</a></td>
                <td>{p.category}</td>
                <td class="num">{formatMsek(promiseTotalMsek(p), p.cost.basis)}</td>
                <td>{p.status}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <KallRad source={`${party.name}:s valprogram`} />

    <Dela path={canonicalPath} title={pageTitle} text={`${party.name}s vallöften 2026 väger ${formatMsekShort(total)} mdkr. Källspårat på drygast.nu`} />
  </div>
</Layout>

<style>
  .manifest-status {
    font-size: 0.85rem;
    color: var(--farg-text-svag, #666);
    font-style: italic;
  }

  .prosa-content--centered {
    margin: 1.5rem auto;
  }
  .sektion {
    margin-top: 2rem;
  }
  .datavy--scroll {
    overflow-x: auto;
  }
</style>
