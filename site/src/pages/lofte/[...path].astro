---
import Layout from "../../layouts/Layout.astro";
import ArendeHuvud from "../../components/ArendeHuvud.astro";
import Stampel from "../../components/Stampel.astro";
import Citat from "../../components/Citat.astro";
import Marginalanteckning from "../../components/Marginalanteckning.astro";
import MetodLank from "../../components/MetodLank.astro";
import KallRad from "../../components/KallRad.astro";
import { getPromises, getParties, getPeople, getConstants } from "../../lib/data";
import { formatMsek, formatBasisLabel, formatCostType, formatDateShort, getPartyByCode } from "../../lib/calc";
import { promiseTotalMsek, computeComparisons, formatComparison, dryLine } from "../../lib/aggregates";

export function getStaticPaths() {
  const promises = getPromises();
  return promises.map((p) => ({
    params: { path: `${p.id}/${p.slug}` },
    props: { promise: p },
  }));
}

const { promise } = Astro.props;
const parties = getParties();
const people = getPeople();
const constants = getConstants();
const partyNames = promise.parties.map((c) => getPartyByCode(parties, c)?.name || c).join(', ');
const total = formatMsek(promiseTotalMsek(promise), promise.cost.basis);
const personName = promise.person?.name || null;
const comparisons = computeComparisons(promise, constants);
const canonicalPath = `/lofte/${promise.id}/${promise.slug}`;
const totalBasis = promise.cost.basis;

const pageTitle = totalBasis === 'llm_estimat'
  ? `Vad kostar löftet "${promise.title}"? ≈ ${formatMsek(promiseTotalMsek(promise), totalBasis)} — drygast.nu`
  : `Vad kostar löftet "${promise.title}"? ${formatMsek(promiseTotalMsek(promise), totalBasis)} — drygast.nu`;

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": promise.title,
    "description": `${partyNames} lovar: ${promise.title}. Kostnad: ${total}.`,
    "url": `https://drygast.nu${canonicalPath}`,
    "datePublished": promise.date_stated,
    "author": {
      "@type": "Organization",
      "name": "drygast.nu",
    },
    "publisher": {
      "@type": "Organization",
      "name": "drygast.nu",
    },
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Hem", "item": "https://drygast.nu/" },
      { "@type": "ListItem", "position": 2, "name": promise.title, "item": `https://drygast.nu${canonicalPath}` },
    ],
  },
];
---
<Layout title={pageTitle} description={`${partyNames} lovar: ${promise.title}. Kostnad: ${total}.`} ogImage={`/og/${promise.id}/og.png`} jsonLd={jsonLd} canonicalPath={canonicalPath}>
  <div class="page-content">
    <div class="prosa-content prosa-content--centered">
      <ArendeHuvud id={promise.id} dateStated={promise.date_stated} domain={promise.source.domain} status={promise.status} />

      <h1>{promise.title}</h1>

      {(promise.status === 'uppdaterad' || promise.status === 'tillbakadragen') && (
        <div class="stampel-wrap">
          <Stampel text={promise.status === 'uppdaterad' ? 'UPPDATERAT' : 'TILLBAKADRAGET'} />
        </div>
      )}

      <p class="lofte-summary">
        {partyNames} lovar {promise.title.toLowerCase()}. Kostnad: <strong class="num">{total}</strong> för de fyra åren 2027–2030.
      </p>

      <Citat
        quote={promise.quote}
        person={personName}
        party={partyNames}
        domain={promise.source.domain}
        date={formatDateShort(promise.date_stated)}
        sourceUrl={promise.source.url}
        archiveUrl={promise.source.archive_url}
        kind={promise.source.kind}
      />

      <section class="sektion" id="kostnad">
        <h2>Kostnad</h2>
        <div class="datavy datavy--scroll" tabindex="0" role="region" aria-label="Kostnadstabell">
          <table>
            <thead>
              <tr>
                <th>Typ</th>
                <th>Period</th>
                <th class="num">Lägsta (mkr)</th>
                <th class="num">Troligast (mkr)</th>
                <th class="num">Högsta (mkr)</th>
                <th class="num">Totalt (mdkr)</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>{formatCostType(promise.cost.type)}</td>
                <td>{promise.cost.period === 'per_ar' ? 'per år' : 'engång'}</td>
                <td class="num">{promise.cost.msek_low.toLocaleString('sv-SE')}</td>
                <td class="num">{promise.cost.msek_base.toLocaleString('sv-SE')}</td>
                <td class="num">{promise.cost.msek_high.toLocaleString('sv-SE')}</td>
                <td class="num">{formatMsek(promiseTotalMsek(promise), promise.cost.basis)}</td>
              </tr>
            </tbody>
          </table>
        </div>
        <div class="kostnad-meta">
          Grund: {formatBasisLabel(promise.cost.basis)}{promise.cost.basis_url ? ` · <a href="${promise.cost.basis_url}">källa ↗</a>` : ''}
          <br />
          {promise.cost.method_note}
        </div>
      </section>

      <MetodLank />

      {comparisons.length > 0 && (
        <section class="sektion" id="jamforelse">
          <h2>Jämförelser</h2>
          <ul class="jamforelse-list">
            {comparisons.map((c) => (
              <li>
                {c.unverifiable ? (
                  <span class="etikett etikett--dis-unverified">Värde ej verifierat — {c.label}</span>
                ) : (
                  <span><strong class="num">{formatComparison(c)}</strong></span>
                )}
              </li>
            ))}
          </ul>
        </section>
      )}

      {!promise.financing_claimed.described && (
        <div class="stampel-wrap">
          <Stampel text="FINANSIERING EJ ANGIVEN" />
        </div>
      )}

      {promise.financing_claimed.described && promise.financing_claimed.summary && (
        <div class="finansiering-meta">
          Finansiering: {promise.financing_claimed.summary}
          {promise.financing_claimed.msek && ` (${formatMsek(promise.financing_claimed.msek)})`}
        </div>
      )}

      <Marginalanteckning text={promise.quip || dryLine(promise, constants)} />

      {promise.history.length > 0 && (
        <section class="sektion">
          <h2>Historik</h2>
          <table>
            <thead>
              <tr>
                <th>Datum</th>
                <th>Ändring</th>
              </tr>
            </thead>
            <tbody>
              {promise.history.map((h) => (
                <tr>
                  <td class="num">{formatDateShort(h.date)}</td>
                  <td>{h.change}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </section>
      )}

      <div id="kallor">
        <KallRad source={formatBasisLabel(promise.cost.basis)} date={formatDateShort(promise.source.fetched_at)} />
      </div>
    </div>
  </div>
</Layout>

<style>
  .prosa-content--centered {
    margin: 0 auto;
  }
  .stampel-wrap {
    margin: 0.5rem 0;
  }
  .lofte-summary {
    margin-bottom: var(--mellanrum);
  }
  .sektion {
    margin-top: 1.5rem;
  }
  .datavy--scroll {
    overflow-x: auto;
  }
  .kostnad-meta {
    font-family: var(--font-mono);
    font-size: var(--steg--1);
    color: var(--dis);
    margin-top: 0.5rem;
  }
  .finansiering-meta {
    margin: var(--mellanrum) 0;
    font-family: var(--font-mono);
    font-size: var(--steg--1);
  }
  .jamforelse-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .jamforelse-list li {
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--linje-svag);
    font-size: var(--steg-1);
  }
  .etikett--dis-unverified {
    color: var(--dis);
  }
</style>
