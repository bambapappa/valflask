---
import "../styles/tokens.css";
import "../styles/base.css";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { getPromises, getParties, getChangelog } from "../lib/data";
import { dataHash, isFixture } from "../lib/calc";

const promises = getPromises();
const parties = getParties();
const changelog = getChangelog();
const hash = dataHash(changelog);
const fixture = isFixture(promises);
// "Senast uppdaterad" = senaste changelog-posten: pipelinen appendar en post
// VARJE körning (även utan nya löften) och manuella rättelser loggas också.
// Tidigare lästes promises[0].source.fetched_at — men listan är id-sorterad, så
// det var ÄLDSTA seed-löftets hämtningsdatum: datumet frös vid juni-importen
// och stale-bannern kunde lysa permanent.
const lastRun =
  changelog.length > 0
    ? changelog[changelog.length - 1].timestamp
    : promises.length > 0
      ? promises[0].source.fetched_at
      : new Date().toISOString();

// Stale-läge §15: data >36h äldre än byggtid ⇒ diskret gul banner
const STALE_MS = 36 * 60 * 60 * 1000;
const buildTime = new Date();
const lastRunDate = new Date(lastRun);
const isStale = !fixture && (buildTime.getTime() - lastRunDate.getTime()) > STALE_MS;

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
  hasTaxameter?: boolean;
  jsonLd?: object | object[];
  canonicalPath?: string;
}

const canonicalBase = Astro.site?.origin ?? "https://drygast.nu";
const { title, description = "Oberoende, källspårad sammanställning av svenska riksdagspartiers vallöften.", ogImage = "/og/start.png", hasTaxameter = false, jsonLd, canonicalPath } = Astro.props;
const ogImageUrl = ogImage.startsWith("https://") ? ogImage : `${canonicalBase}${ogImage}`;
const canonicalUrl = canonicalPath ? `${canonicalBase}${canonicalPath}` : new URL(Astro.url.pathname, canonicalBase).href;
const jsonLdArray = jsonLd ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd]) : [];
---
<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:image" content={ogImageUrl} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="twitter:card" content="summary_large_image" />
  <meta property="twitter:image" content={ogImageUrl} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="sv_SE" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="canonical" href={canonicalUrl} />
  <link rel="preload" href="/fonts/anton-latin-400-normal.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/ibm-plex-mono-latin-700-normal.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/source-serif-4-latin-wght-normal.woff2" as="font" type="font/woff2" crossorigin />
  {jsonLdArray.map((item) => (
    <script type="application/ld+json" set:html={JSON.stringify(item)} />
  ))}
</head>
<body>
  <a href="#main" class="skiplank">Hoppa till huvudinnehåll</a>
  <SiteHeader hash={hash} lastRun={lastRun} parties={parties} />
  {fixture && (
    <div class="fixture-banner etikett" role="status">EXEMPELDATA — den riktiga insamlingen är på väg</div>
  )}
  {isStale && (
    <div class="fixture-banner etikett" role="status">Senast uppdaterad {new Date(lastRun).toLocaleDateString("sv-SE")} — data kan vara inaktuell</div>
  )}
  <main id="main">
    <slot />
  </main>
  <SiteFooter hash={hash} />
  {hasTaxameter && <script is:inline src="/taxameter.js"></script>}
</body>
</html>
