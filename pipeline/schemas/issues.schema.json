{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://drygast.nu/schemas/issues.schema.json",
  "title": "Frågevågen — frågor",
  "description": "Valets stora frågor med delfrågor (SPEC-FRAGEVAGEN.md §4.1). Ägar-kuraterad, ändras endast via PR — aldrig av pipelinen. Urvalskriterium: tröghetsregeln (§3).",
  "type": "object",
  "additionalProperties": false,
  "required": ["criteria_note", "formulation_note", "issues"],
  "properties": {
    "criteria_note": { "type": "string", "minLength": 10 },
    "formulation_note": { "type": "string", "minLength": 10 },
    "issues": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "title", "slug", "category", "status", "selection_sources", "subquestions"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^i-[a-z0-9-]+$",
            "description": "Stabilt, ändras aldrig; ingår i URL."
          },
          "title": { "type": "string", "minLength": 2 },
          "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "category": {
            "enum": [
              "välfärd",
              "skatter",
              "försvar",
              "klimat-miljö",
              "rättsväsende",
              "utbildning",
              "infrastruktur",
              "migration",
              "övrigt"
            ],
            "description": "Koppling till löftestaxonomin (SPEC.md §5.1) för korslänkning."
          },
          "status": { "enum": ["aktiv", "dormant"] },
          "selection_sources": {
            "type": "array",
            "minItems": 2,
            "description": "Bevis för att frågan uppfyller tröghetsregeln — minst två oberoende institut.",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["institute", "survey", "url", "date", "rank", "share_percent"],
              "properties": {
                "institute": { "type": "string", "minLength": 2 },
                "survey": { "type": "string", "minLength": 2 },
                "url": { "type": "string", "pattern": "^https://" },
                "date": { "type": "string", "pattern": "^\\d{4}-\\d{2}(-\\d{2})?$" },
                "rank": {
                  "type": ["integer", "null"],
                  "minimum": 1,
                  "description": "null när institutet inte publicerar exakt placering (t.ex. SOM:s topp 15 utan rangnummer) — förklaras då i note."
                },
                "share_percent": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
                "note": { "type": "string" }
              }
            }
          },
          "subquestions": {
            "type": "array",
            "minItems": 1,
            "maxItems": 4,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": ["id", "text", "formulation_status", "fairness_note"],
              "properties": {
                "id": { "type": "string", "pattern": "^sq-[a-z0-9-]+$" },
                "text": {
                  "type": "string",
                  "minLength": 10,
                  "pattern": "\\?$",
                  "description": "Konkret, ja/nej-besvarbar fråga utan värdeladdade ord."
                },
                "formulation_status": {
                  "enum": ["utkast", "verifierad"],
                  "description": "Alla delfrågor ska vara 'verifierad' innan V3 (skarp drift)."
                },
                "fairness_note": {
                  "type": "string",
                  "minLength": 10,
                  "description": "Dokumenterat rättvisetest: varför formuleringen accepteras av båda sidor (§2.2)."
                }
              }
            }
          }
        }
      }
    }
  }
}
