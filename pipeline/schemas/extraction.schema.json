{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://drygast.nu/schemas/extraction.schema.json",
  "title": "Extraktionskandidat",
  "description": "En kandidat ur LLM A:s svar (prompt A1). Valideras i grind G1 (§7) med additionalProperties:false som injektionshygien — fält utöver kontraktet släpps aldrig vidare i pipelinen.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "title",
    "parties",
    "person",
    "quote",
    "category",
    "amount_in_text_msek",
    "financing_mentioned"
  ],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 5,
      "maxLength": 160
    },
    "parties": {
      "type": "array",
      "minItems": 1,
      "maxItems": 8,
      "uniqueItems": true,
      "items": {
        "enum": ["s", "m", "sd", "c", "v", "kd", "l", "mp"]
      }
    },
    "person": {
      "oneOf": [
        { "type": "null" },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "role"],
          "properties": {
            "name": { "type": "string", "minLength": 2, "maxLength": 80 },
            "role": { "type": "string", "minLength": 2, "maxLength": 80 },
            "riksdagen_id": {
              "type": ["string", "null"],
              "pattern": "^[0-9]{1,20}$"
            }
          }
        }
      ]
    },
    "quote": {
      "type": "string",
      "minLength": 10,
      "maxLength": 600
    },
    "category": {
      "enum": [
        "välfärd",
        "skatter",
        "försvar",
        "klimat-miljö",
        "rättsväsende",
        "utbildning",
        "infrastruktur",
        "migration",
        "övrigt"
      ]
    },
    "amount_in_text_msek": {
      "type": ["number", "null"],
      "minimum": 0,
      "maximum": 100000000
    },
    "financing_mentioned": {
      "type": "boolean"
    }
  }
}
