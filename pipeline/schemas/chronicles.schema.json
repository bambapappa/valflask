{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://drygast.nu/schemas/chronicles.schema.json",
  "title": "Veckokrönikor",
  "description": "Veckans fläsk (§7 steg 7, bilaga A4). En post per ISO-vecka, genererad av LLM C ur veckans nya löften.",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": ["year", "week", "slug", "headline", "body_md", "promise_ids", "total_msek", "gap_msek", "generated_at", "run_id"],
    "properties": {
      "year": { "type": "integer", "minimum": 2025, "maximum": 2030 },
      "week": { "type": "integer", "minimum": 1, "maximum": 53 },
      "slug": { "type": "string", "pattern": "^\\d{4}-\\d{2}$" },
      "headline": { "type": "string", "minLength": 3, "maxLength": 160 },
      "body_md": { "type": "string", "minLength": 1 },
      "promise_ids": {
        "type": "array",
        "items": { "type": "string", "pattern": "^p-\\d{4}-\\d{4}$" }
      },
      "total_msek": { "type": "number", "minimum": 0 },
      "gap_msek": { "type": "number" },
      "generated_at": { "type": "string" },
      "run_id": { "type": "string", "minLength": 1 },
      "correction_note": { "type": "string", "minLength": 10, "description": "Synlig rättelsenot på krönikans sida (tyst rättelse är förbjuden). Sätts manuellt vid rättelse; listas även på /rattelser." }
    }
  }
}
