{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://drygast.nu/schemas/promises.schema.json",
  "title": "Löften",
  "description": "Array av vallöften (§5.1). Varje post är ett kanoniskt löfte som committas av pipeline-boten.",
  "type": "array",
  "items": {
    "type": "object",
    "additionalProperties": false,
    "required": [
      "id",
      "title",
      "slug",
      "parties",
      "person",
      "quote",
      "date_stated",
      "source",
      "category",
      "cost",
      "financing_claimed",
      "comparisons",
      "quip",
      "status",
      "history",
      "extraction"
    ],
    "properties": {
      "id": {
        "type": "string",
        "pattern": "^p-\\d{4}-\\d{4}$"
      },
      "group_id": {
        "type": [
          "string",
          "null"
        ],
        "pattern": "^g-[a-z0-9-]+$"
      },
      "title": {
        "type": "string",
        "minLength": 5,
        "maxLength": 160
      },
      "slug": {
        "type": "string",
        "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
      },
      "parties": {
        "type": "array",
        "minItems": 1,
        "maxItems": 8,
        "uniqueItems": true,
        "items": {
          "enum": [
            "s",
            "m",
            "sd",
            "c",
            "v",
            "kd",
            "l",
            "mp"
          ]
        }
      },
      "person": {
        "oneOf": [
          {
            "type": "null"
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "name",
              "role"
            ],
            "properties": {
              "name": {
                "type": "string",
                "minLength": 2,
                "maxLength": 80
              },
              "role": {
                "type": "string",
                "minLength": 2,
                "maxLength": 80
              },
              "riksdagen_id": {
                "type": [
                  "string",
                  "null"
                ],
                "pattern": "^[0-9]{1,20}$"
              }
            }
          }
        ]
      },
      "quote": {
        "type": "string",
        "minLength": 10,
        "maxLength": 600
      },
      "date_stated": {
        "type": "string",
        "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
      },
      "source": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "url",
          "domain",
          "archive_url",
          "fetched_at"
        ],
        "properties": {
          "url": {
            "type": "string",
            "pattern": "^https://"
          },
          "domain": {
            "type": "string",
            "minLength": 1
          },
          "archive_url": {
            "oneOf": [
              {
                "type": "string",
                "pattern": "^https://web\\.archive\\.org/"
              },
              {
                "type": "null"
              }
            ]
          },
          "fetched_at": {
            "type": "string"
          },
          "kind": {
            "type": "string",
            "enum": [
              "webb",
              "tal"
            ]
          }
        }
      },
      "category": {
        "enum": [
          "välfärd",
          "skatter",
          "försvar",
          "klimat-miljö",
          "rättsväsende",
          "utbildning",
          "infrastruktur",
          "migration",
          "övrigt"
        ]
      },
      "cost": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "type",
          "period",
          "msek_low",
          "msek_base",
          "msek_high",
          "basis",
          "basis_url",
          "method_note",
          "confidence"
        ],
        "properties": {
          "type": {
            "enum": [
              "utgift",
              "intäktsminskning",
              "besparing",
              "intäktsökning"
            ]
          },
          "period": {
            "enum": [
              "per_ar",
              "engang"
            ]
          },
          "msek_low": {
            "type": "number",
            "minimum": 0
          },
          "msek_base": {
            "type": "number",
            "minimum": 0
          },
          "msek_high": {
            "type": "number",
            "minimum": 0
          },
          "basis": {
            "enum": [
              "rut",
              "myndighet",
              "parti",
              "media",
              "llm_estimat"
            ]
          },
          "basis_url": {
            "type": [
              "string",
              "null"
            ]
          },
          "method_note": {
            "type": "string",
            "minLength": 1
          },
          "calculation": {
            "type": "string",
            "minLength": 1,
            "maxLength": 800
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        }
      },
      "financing_claimed": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "described"
        ],
        "properties": {
          "described": {
            "type": "boolean"
          },
          "summary": {
            "type": [
              "string",
              "null"
            ]
          },
          "msek": {
            "type": [
              "number",
              "null"
            ],
            "minimum": 0
          }
        }
      },
      "comparisons": {
        "type": "array",
        "items": {
          "type": "string"
        }
      },
      "quip": {
        "type": [
          "string",
          "null"
        ]
      },
      "status": {
        "enum": [
          "aktiv",
          "uppdaterad",
          "tillbakadragen",
          "infriad"
        ]
      },
      "history": {
        "type": "array",
        "items": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "date",
            "change",
            "commit"
          ],
          "properties": {
            "date": {
              "type": "string"
            },
            "change": {
              "type": "string"
            },
            "commit": {
              "type": "string",
              "pattern": "^[0-9a-f]{7,40}$"
            }
          }
        }
      },
      "extraction": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "model",
          "verified_by",
          "run_id"
        ],
        "properties": {
          "model": {
            "type": "string"
          },
          "verified_by": {
            "type": [
              "string",
              "null"
            ]
          },
          "run_id": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
