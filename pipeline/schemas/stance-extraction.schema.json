{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://drygast.nu/schemas/stance-extraction.schema.json",
  "title": "Frågevågen — extraktionskandidat (A6)",
  "description": "En kandidat ur LLM A:s A6-svar. Valideras per kandidat i G1 (stance). additionalProperties:false är injektionshygien — okända fält fäller kandidaten.",
  "type": "object",
  "additionalProperties": false,
  "required": ["subquestion_id", "party", "position", "condition_note", "quote", "person"],
  "properties": {
    "subquestion_id": { "type": "string", "minLength": 4, "maxLength": 80 },
    "party": { "enum": ["s", "m", "sd", "c", "v", "kd", "l", "mp"] },
    "position": { "enum": ["ja", "nej", "villkorat"] },
    "condition_note": { "type": ["string", "null"], "maxLength": 300 },
    "quote": { "type": "string", "minLength": 10, "maxLength": 600 },
    "person": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["name", "role"],
      "properties": {
        "name": { "type": "string", "minLength": 2, "maxLength": 100 },
        "role": { "type": "string", "minLength": 2, "maxLength": 100 }
      }
    }
  }
}
